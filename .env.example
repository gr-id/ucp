# 2nd PoC environment variables
# Copy this file to `.env` and fill in your own values, or set as env vars.

# Catalog mode for the merchant service: `mock` or `serpapi`. Default: mock.
# When set to `serpapi`, the merchant calls Google Shopping via SerpAPI.
UCP_CATALOG_MODE=mock

# SerpAPI key — required when UCP_CATALOG_MODE=serpapi.
# Free tier: 250 searches/month. Get one at https://serpapi.com/users/sign_up
SERPAPI_KEY=
