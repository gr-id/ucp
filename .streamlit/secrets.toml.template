# Streamlit Community Cloud secrets — paste into App settings → Secrets.
# Locally, .env is used instead (see .env.example).
#
# Copy this file to .streamlit/secrets.toml for local testing (gitignored).

# Catalog mode for the merchant service. "mock" or "serpapi".
UCP_CATALOG_MODE = "serpapi"

# Operator-supplied SerpAPI key (free tier 250/month at https://serpapi.com).
# Each visitor can override this in the sidebar with their own key.
SERPAPI_KEY = ""
